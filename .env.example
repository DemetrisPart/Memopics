# =============================================================================
# Memopics — Environment Variables (copy to .env at repo root)
# =============================================================================

# App
NODE_ENV=development
APP_ENV=development
SERVICE_NAME=memopics
LOG_LEVEL=debug

# Web (Next.js)
WEB_APP_URL=http://localhost:3000

# Public event page URLs (QR codes, sharing)
# Local: http://localhost:3000  |  Production: https://memopics.com
PUBLIC_EVENT_BASE_URL=http://localhost:3000

# API (NestJS)
API_PORT=3001
API_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://memopics:memopics@localhost:5432/memopics?schema=public

# Redis (BullMQ — Phase 3)
REDIS_URL=redis://localhost:6379

# Object Storage — MinIO local / Cloudflare R2 production
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=memopics
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true

# Production R2 example (do not commit real credentials):
# STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_BUCKET=memopics-production
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_FORCE_PATH_STYLE=true

# Email — Mailpit local / Resend production
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=Memopics <noreply@memopics.com>
MAILPIT_WEB_URL=http://localhost:8025
# RESEND_API_KEY=

# Auth (Phase 1)
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-in-production-min-32!!
MAGIC_LINK_TTL_MINUTES=15

# JWT cookie names
ACCESS_TOKEN_COOKIE=memopics_access
REFRESH_TOKEN_COOKIE=memopics_refresh
GUEST_SESSION_COOKIE=memopics_guest

# Rate limiting (Redis-backed — Phase 3 hardening)
RATE_LIMIT_API_GLOBAL_PER_IP_MINUTE=120
RATE_LIMIT_GUEST_SESSION_PER_IP_HOUR=10
RATE_LIMIT_UPLOAD_INIT_PER_SESSION_HOUR=30
RATE_LIMIT_UPLOAD_COMPLETE_PER_SESSION_HOUR=60

# Worker (Phase 3)
WORKER_MEDIA_CONCURRENCY=2
MEDIA_QUEUE_JOB_ATTEMPTS=3

# API resilience
# Request timeout is fixed at 30s via API_REQUEST_TIMEOUT_MS in @memopics/shared
