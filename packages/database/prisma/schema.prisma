// Prisma schema — Memopics MVP
// Timestamps + soft delete on important tables for GDPR, expiration, recovery.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  COUPLE
  PLATFORM_ADMIN
}

enum EventStatus {
  ACTIVE
  EXPIRED
  DELETED
}

enum PrivacyMode {
  OWN_UPLOADS_ONLY
  ALL_GUESTS
}

enum MediaAssetType {
  PHOTO
  VIDEO
  AI_OUTPUT
}

enum MediaAssetStatus {
  PENDING
  PROCESSING
  ACTIVE
  FAILED
  QUARANTINED
}

enum MediaVariantType {
  THUMB
  WEB
  HLS_360
  HLS_720
  HLS_1080
  POSTER
}

enum UploadBatchStatus {
  PENDING
  UPLOADING
  COMPLETED
  PARTIAL
  FAILED
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  role              UserRole  @default(COUPLE)
  emailVerifiedAt   DateTime? @map("email_verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  events            Event[]
  magicLinkTokens   MagicLinkToken[]
  refreshTokens     RefreshToken[]

  @@index([deletedAt])
  @@map("users")
}

model MagicLinkToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("magic_link_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Event {
  id                     String       @id @default(uuid()) @db.Uuid
  slug                   String       @unique
  qrToken                String       @unique @map("qr_token")
  ownerUserId            String       @map("owner_user_id") @db.Uuid
  brideName              String?      @map("bride_name")
  groomName              String?      @map("groom_name")
  title                  String
  eventDate              DateTime     @map("event_date") @db.Date
  coverImageMediaId      String?      @unique @map("cover_image_media_id") @db.Uuid
  status                 EventStatus  @default(ACTIVE)
  privacyMode            PrivacyMode  @default(OWN_UPLOADS_ONLY) @map("privacy_mode")
  showGuestNamesPublicly Boolean      @default(true) @map("show_guest_names_publicly")
  storageUsedBytes       BigInt       @default(0) @map("storage_used_bytes")
  storageLimitBytes      BigInt       @default(21474836480) @map("storage_limit_bytes") // 20 GB
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")
  deletedAt              DateTime?    @map("deleted_at")

  owner         User           @relation(fields: [ownerUserId], references: [id])
  coverImage    MediaAsset?    @relation("EventCoverImage", fields: [coverImageMediaId], references: [id])
  guestSessions GuestSession[]
  uploadBatches UploadBatch[]
  mediaAssets   MediaAsset[]   @relation("EventMediaAssets")

  @@index([ownerUserId])
  @@index([status])
  @@index([deletedAt])
  @@map("events")
}

model GuestSession {
  id               String    @id @default(uuid()) @db.Uuid
  eventId          String    @map("event_id") @db.Uuid
  firstName        String    @map("first_name")
  lastName         String?   @map("last_name")
  sessionTokenHash String    @unique @map("session_token_hash")
  ipHash           String?   @map("ip_hash")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadBatches UploadBatch[]
  mediaAssets   MediaAsset[]

  @@index([eventId])
  @@index([eventId, createdAt])
  @@index([deletedAt])
  @@map("guest_sessions")
}

model UploadBatch {
  id              String            @id @default(uuid()) @db.Uuid
  eventId         String            @map("event_id") @db.Uuid
  guestSessionId  String            @map("guest_session_id") @db.Uuid
  uploadSessionId String            @map("upload_session_id")
  status          UploadBatchStatus @default(PENDING)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guestSession GuestSession @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  mediaAssets  MediaAsset[]

  @@index([eventId])
  @@index([eventId, createdAt])
  @@index([guestSessionId])
  @@index([uploadSessionId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("upload_batches")
}

model MediaAsset {
  id                String           @id @default(uuid()) @db.Uuid
  eventId           String           @map("event_id") @db.Uuid
  guestSessionId    String?          @map("guest_session_id") @db.Uuid
  uploadBatchId     String?          @map("upload_batch_id") @db.Uuid
  type              MediaAssetType
  status            MediaAssetStatus @default(PENDING)
  originalKey       String           @map("original_key")
  originalSizeBytes BigInt           @map("original_size_bytes")
  mimeType          String           @map("mime_type")
  width             Int?
  height            Int?
  durationMs        Int?             @map("duration_ms")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")

  event        Event         @relation("EventMediaAssets", fields: [eventId], references: [id], onDelete: Cascade)
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id])
  uploadBatch  UploadBatch?  @relation(fields: [uploadBatchId], references: [id])
  variants     MediaVariant[]
  coverForEvent Event?       @relation("EventCoverImage")

  @@index([eventId])
  @@index([eventId, status])
  @@index([eventId, createdAt])
  @@index([guestSessionId])
  @@index([guestSessionId, createdAt])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("media_assets")
}

model MediaVariant {
  id           String           @id @default(uuid()) @db.Uuid
  mediaAssetId String           @map("media_asset_id") @db.Uuid
  variant      MediaVariantType
  storageKey   String           @map("storage_key")
  sizeBytes    BigInt           @map("size_bytes")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([mediaAssetId, variant])
  @@index([mediaAssetId])
  @@map("media_variants")
}
